Django用の一般的な .gitignore

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
env/
venv/
ENV/
.venv/

# Pyenv
.python-version

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Django / project specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/    
#collectstatic 出力先（必要に応じて除外）
# 静的ファイルのビルド成果物（例: Webpack）
node_modules/
npm-debug.log*
yarn-error.log

# Environment variables
.env
.env.prod
.env.*

# Testing / coverage
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Celery
celerybeat-schedule
celerybeat.pid

# Sphinx
docs/_build/

# Misc
*.pot
*.mo
*.log.*
*.sqlite3
._*

.env_example

# Docker volume garbage
*.pid
*.sock